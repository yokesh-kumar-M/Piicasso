# AEGIS CORE -- Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# Django Core
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False
ENV=production

# Comma-separated list of allowed hosts (no spaces)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL in production)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Cache / Session (Redis)
REDIS_URL=redis://localhost:6379/0

# CORS -- comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:3000

# JWT Token lifetimes
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=7

# HTTPS -- set to True when behind a TLS-terminating proxy or load balancer
SECURE_SSL_REDIRECT=True

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# App Settings
MAX_WORDLIST_SIZE=1000
GEMINI_API_KEY=your-gemini-api-key
DATA_RETENTION_DAYS=30
TIME_ZONE=UTC

# Google OAuth (from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
