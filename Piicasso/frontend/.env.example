# PIIcasso Frontend — Environment Variables
# Copy to .env.local for local development

# Backend API base URL (include trailing slash)
# Development: http://localhost:8000/api/
# Production: https://your-render-backend.onrender.com/api/
REACT_APP_API_URL=http://localhost:8000/api/

# Google OAuth Client ID
# Generate at: https://console.cloud.google.com/ → APIs & Services → Credentials
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
