{
    "buildCommand": "cd frontend && npm i && npm run build",
    "outputDirectory": "frontend/build",
    "framework": "create-react-app",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://piicasso.onrender.com/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}