{
  "mcpServers": {
    "claude-flow": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "ruflo@latest",
        "mcp",
        "start"
      ],
      "env": {
        "npm_config_update_notifier": "false",
        "CLAUDE_FLOW_MODE": "v3",
        "CLAUDE_FLOW_HOOKS_ENABLED": "true",
        "CLAUDE_FLOW_TOPOLOGY": "hierarchical-mesh",
        "CLAUDE_FLOW_MAX_AGENTS": "15",
        "CLAUDE_FLOW_MEMORY_BACKEND": "hybrid"
      },
      "autoStart": false
    },
    "render-mcp": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@niyogi/render-mcp"
      ],
      "env": {
        "RENDER_API_KEY": "rnd_kojYoodQ8fbQwr7QxMivkuL6oB8c"
      },
      "autoStart": false
    }
  }
}
